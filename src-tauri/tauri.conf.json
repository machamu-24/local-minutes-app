{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Local Minutes",
  "version": "0.1.0",
  "identifier": "com.machamu.localminutes",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd frontend && pnpm dev",
    "beforeBuildCommand": "cd frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Local Minutes",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/local-minutes-backend",
      "binaries/llama-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
